# LLM Gateway Configuration
# Copy this file to .env and fill in your values

# ============================================
# Required API Keys
# ============================================

# Gateway authentication
GATEWAY_API_KEY=your-gateway-api-key-here

# Provider API keys (at least one required)
GROQ_API_KEY=your-groq-api-key
CEREBRAS_API_KEY=your-cerebras-api-key
MISTRAL_API_KEY=your-mistral-api-key
GEMINI_API_KEY=your-gemini-api-key
NIM_API_KEY=your-nim-api-key
OLLAMA_API_KEY=your-ollama-api-key
KILO_API_KEY=your-kilo-api-key

# Google Vertex AI (uses Application Default Credentials)
# On GCP (Cloud Run, GKE, Compute Engine): works automatically, no config needed
# For local dev: run `gcloud auth application-default login`
# For container/Coolify: use GCP_SA_KEY_JSON below
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# GCP location/region (default: global)
# Examples: global, us-central1, europe-west1
GOOGLE_CLOUD_LOCATION=global

# Service account JSON key (for containerized/Coolify deployment)
# Copy the full JSON content from your GCP service account key file
# IMPORTANT: Never commit this value to source control
# DO NOT wrap in quotes - use literal newlines
GCP_SA_KEY_JSON=

# ============================================
# Server Configuration
# ============================================

# Server port (default: 8080)
PORT=8080

# Metrics port for Prometheus scraping (default: 9090)
# This port should NOT be exposed to the internet.
# In Docker, bind to 127.0.0.1 only: 127.0.0.1:9090:9090
METRICS_PORT=9090

# Environment (development/production)
ENV=production

# Log level (debug/info/warn/error)
LOG_LEVEL=info

# ============================================
# Redis Configuration
# ============================================

# Redis URL (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# Redis key prefix (default: llm_gateway)
REDIS_KEY_PREFIX=llm_gateway

# ============================================
# Rate Limiting
# ============================================

# Requests per IP per window (default: 100)
RATE_LIMIT_PER_IP=100

# Rate limit window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# CORS Configuration
# ============================================

# Allowed CORS origins (comma-separated, empty = allow all)
# Example: CORS_ORIGINS=https://example.com,https://app.example.com
CORS_ORIGINS=

# ============================================
# Docker Compose Settings
# ============================================

# External port mapping (default: 8080)
EXTERNAL_PORT=8080
